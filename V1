-- BAR
local bar = Instance.new("Frame")
bar.Size = UDim2.new(0,0,1,0)
bar.BackgroundColor3 = Color3.fromRGB(0,255,100)
bar.Parent = barBG

Instance.new("UICorner", bar).CornerRadius = UDim.new(1,0)

local gradient = Instance.new("UIGradient")
gradient.Color = ColorSequence.new{
	ColorSequenceKeypoint.new(0, Color3.fromRGB(100,255,100)),
	ColorSequenceKeypoint.new(1, Color3.fromRGB(0,200,60))
}
gradient.Parent = bar

-- SHINE EFFECT
local shine = Instance.new("Frame")
shine.Size = UDim2.new(0,60,1,0)
shine.BackgroundColor3 = Color3.new(1,1,1)
shine.BackgroundTransparency = 0.7
shine.Parent = bar

local shineCorner = Instance.new("UICorner")
shineCorner.CornerRadius = UDim.new(1,0)
shineCorner.Parent = shine

-- TIPS
local tips = {
	"🌱 Water crops for faster growth!",
	"🍓 Rare seeds are worth more money!",
	"🐝 Bees help your garden grow!",
	"🥕 Harvest often for maximum profit!",
	"🌻 Expand your garden to unlock more crops!"
}

local tip = Instance.new("TextLabel")
tip.Size = UDim2.new(0.7,0,0.04,0)
tip.Position = UDim2.new(0.15,0,0.88,0)
tip.BackgroundTransparency = 1
tip.TextScaled = true
tip.Font = Enum.Font.Gotham
tip.TextColor3 = Color3.new(1,1,1)
tip.Text = tips[1]
tip.Parent = overlay

-- CHANGE TIPS
task.spawn(function()
	local index = 1

	while gui.Parent do
		task.wait(5)

		index += 1
		if index > #tips then
			index = 1
		end

		tip.Text = tips[index]
	end
end)

-- FLOATING TITLE
task.spawn(function()
	while gui.Parent do
		TweenService:Create(
			title,
			TweenInfo.new(2, Enum.EasingStyle.Sine),
			{Position = UDim2.new(0.15,0,0.075,0)}
		):Play()

		task.wait(2)

		TweenService:Create(
			title,
			TweenInfo.new(2, Enum.EasingStyle.Sine),
			{Position = UDim2.new(0.15,0,0.085,0)}
		):Play()

		task.wait(2)
	end
end)

-- EXACTLY 100 SECONDS
for i = 0,100 do

	percent.Text = i.."%"

	TweenService:Create(
		bar,
		TweenInfo.new(0.95, Enum.EasingStyle.Quad),
		{
			Size = UDim2.new(i/100,0,1,0)
		}
	):Play()

	TweenService:Create(
		shine,
		TweenInfo.new(0.9),
		{
			Position = UDim2.new(1,-60,0,0)
		}
	):Play()

	shine.Position = UDim2.new(0,0,0,0)

	task.wait(1) -- 100 seconds total
end

loading.Text = "Loading Complete!"
percent.Text = "100%"

task.wait(2)

TweenService:Create(
	gui,
	TweenInfo.new(1),
	{
		DisplayOrder = -100
	}
):Play()

gui:Destroy()
