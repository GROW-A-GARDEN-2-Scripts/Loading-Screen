local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
local gui = Instance.new("ScreenGui")
gui.Name = "GrowGarden2Loading"
gui.IgnoreGuiInset = true
gui.ResetOnSpawn = false
gui.Parent = player:WaitForChild("PlayerGui")

-- Background
local bg = Instance.new("Frame")
bg.Size = UDim2.fromScale(1,1)
bg.Parent = gui
bg.BackgroundColor3 = Color3.fromRGB(25,40,25)

local gradient = Instance.new("UIGradient")
gradient.Color = ColorSequence.new{
	ColorSequenceKeypoint.new(0, Color3.fromRGB(35,160,70)),
	ColorSequenceKeypoint.new(1, Color3.fromRGB(20,80,40))
}
gradient.Rotation = 90
gradient.Parent = bg

-- Blur Overlay
local overlay = Instance.new("Frame")
overlay.Size = UDim2.fromScale(1,1)
overlay.BackgroundColor3 = Color3.new(0,0,0)
overlay.BackgroundTransparency = 0.4
overlay.Parent = bg

-- Title
local title = Instance.new("TextLabel")
title.Size = UDim2.new(0.7,0,0.12,0)
title.Position = UDim2.new(0.15,0,0.15,0)
title.BackgroundTransparency = 1
title.Text = "🌱 GROW A GARDEN 2"
title.Font = Enum.Font.FredokaOne
title.TextScaled = true
title.TextColor3 = Color3.new(1,1,1)
title.Parent = bg

local stroke = Instance.new("UIStroke")
stroke.Thickness = 4
stroke.Color = Color3.new(0,0,0)
stroke.Parent = title

-- Subtitle
local subtitle = Instance.new("TextLabel")
subtitle.Size = UDim2.new(0.6,0,0.05,0)
subtitle.Position = UDim2.new(0.2,0,0.28,0)
subtitle.BackgroundTransparency = 1
subtitle.Text = "Plant • Grow • Harvest • Expand"
subtitle.Font = Enum.Font.GothamBold
subtitle.TextScaled = true
subtitle.TextColor3 = Color3.fromRGB(220,255,220)
subtitle.Parent = bg

-- Main Panel
local panel = Instance.new("Frame")
panel.Size = UDim2.new(0.65,0,0.18,0)
panel.Position = UDim2.new(0.175,0,0.58,0)
panel.BackgroundColor3 = Color3.fromRGB(20,20,20)
panel.Parent = bg

Instance.new("UICorner", panel).CornerRadius = UDim.new(0,18)

-- Progress Bar Background
local barBG = Instance.new("Frame")
barBG.Size = UDim2.new(0.9,0,0.25,0)
barBG.Position = UDim2.new(0.05,0,0.45,0)
barBG.BackgroundColor3 = Color3.fromRGB(50,50,50)
barBG.Parent = panel

Instance.new("UICorner", barBG).CornerRadius = UDim.new(1,0)

-- Progress Fill
local fill = Instance.new("Frame")
fill.Size = UDim2.new(0,0,1,0)
fill.BackgroundColor3 = Color3.fromRGB(50,255,100)
fill.Parent = barBG

Instance.new("UICorner", fill).CornerRadius = UDim.new(1,0)

local fillGradient = Instance.new("UIGradient")
fillGradient.Color = ColorSequence.new{
	ColorSequenceKeypoint.new(0, Color3.fromRGB(100,255,100)),
	ColorSequenceKeypoint.new(1, Color3.fromRGB(30,200,60))
}
fillGradient.Parent = fill

-- Percentage
local percent = Instance.new("TextLabel")
percent.Size = UDim2.new(1,0,0.3,0)
percent.BackgroundTransparency = 1
percent.Text = "0%"
percent.Font = Enum.Font.GothamBlack
percent.TextScaled = true
percent.TextColor3 = Color3.new(1,1,1)
percent.Parent = panel

-- Tips
local tips = {
	"🌻 Water crops for faster growth!",
	"🍓 Rare seeds give bigger profits!",
	"🥕 Expand your garden to earn more!",
	"🌱 Harvest often to maximize income!"
}

local tipLabel = Instance.new("TextLabel")
tipLabel.Size = UDim2.new(0.9,0,0.25,0)
tipLabel.Position = UDim2.new(0.05,0,0.75,0)
tipLabel.BackgroundTransparency = 1
tipLabel.TextScaled = true
tipLabel.Font = Enum.Font.Gotham
tipLabel.TextColor3 = Color3.fromRGB(230,230,230)
tipLabel.Text = tips[1]
tipLabel.Parent = panel

-- Floating animation
task.spawn(function()
	while gui.Parent do
		TweenService:Create(
			title,
			TweenInfo.new(2, Enum.EasingStyle.Sine),
			{Position = UDim2.new(0.15,0,0.145,0)}
		):Play()

		task.wait(2)

		TweenService:Create(
			title,
			TweenInfo.new(2, Enum.EasingStyle.Sine),
			{Position = UDim2.new(0.15,0,0.155,0)}
		):Play()

		task.wait(2)
	end
end)

-- Change tips
task.spawn(function()
	local index = 1
	while gui.Parent do
		task.wait(5)
		index += 1
		if index > #tips then
			index = 1
		end
		tipLabel.Text = tips[index]
	end
end)

-- EXACTLY 100 SECONDS
for i = 0, 100 do
	percent.Text = i.."%"

	TweenService:Create(
		fill,
		TweenInfo.new(0.8, Enum.EasingStyle.Quad),
		{Size = UDim2.new(i/100,0,1,0)}
	):Play()

	task.wait(1)
end

percent.Text = "LOADING COMPLETE!"

task.wait(1.5)

TweenService:Create(
	bg,
	TweenInfo.new(1),
	{BackgroundTransparency = 1}
):Play()

task.wait(1)

gui:Destroy()
